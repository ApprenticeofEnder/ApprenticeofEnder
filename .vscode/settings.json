{
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "import (builtins.getFlake \"${workspaceFolder}\").inputs.nixpkgs { }"
      },
      "formatting": {
        "command": ["alejandra"]
      },
      "options": {
        "home-manager": {
          "expr": "let flake = builtins.getFlake(toString ./.); in flake.home-configurations."
        }
      }
    }
  }
}
